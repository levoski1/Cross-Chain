{
  "name": "@drips-protocol/cross-chain-splitter",
  "version": "1.0.0",
  "description": "Post-Wave payout distribution and ecosystem Pay-it-Forward protocol",
  "keywords": ["drips", "solidity", "ethereum", "splitter", "wave", "payout"],
  "homepage": "https://github.com/drips-protocol/cross-chain-splitter",
  "license": "MIT",
  "author": "Drips Protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/drips-protocol/cross-chain-splitter.git"
  },
  "scripts": {
    "build": "hardhat compile",
    "build:force": "hardhat compile --force",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/",
    "test:integration": "hardhat test test/integration/",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint:ts": "eslint 'scripts/**/*.ts' 'test/**/*.ts' --fix",
    "lint": "npm run lint:sol && npm run lint:ts",
    "format": "prettier --write '**/*.{sol,ts,json,yml,yaml}'",
    "format:check": "prettier --check '**/*.{sol,ts,json,yml,yaml}'",
    "slither": "slither . --config-file slither.config.json",
    "deploy:all": "hardhat run scripts/deploy/deploy-all.ts --network",
    "deploy:escrow": "hardhat run scripts/deploy/deploy-escrow.ts --network",
    "deploy:reputation": "hardhat run scripts/deploy/deploy-reputation.ts --network",
    "deploy:scoping": "hardhat run scripts/deploy/deploy-scoping.ts --network",
    "deploy:splitter": "hardhat run scripts/deploy/deploy-splitter.ts --network",
    "verify": "hardhat run scripts/utils/verify.ts --network",
    "generate:types": "hardhat typechain",
    "precommit": "lint-staged",
    "prepare": "husky",
    "postinstall": "husky",
    "task:configure-split": "hardhat splitter:configure",
    "task:split-payout": "hardhat splitter:payout",
    "task:create-wave": "hardhat escrow:create",
    "task:view-config": "hardhat splitter:config",
    "env:check": "ts-node -e \"require('./scripts/utils/env').validateEnv()\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.7",
    "@nomicfoundation/hardhat-ethers": "^3.0.6",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.6",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.14",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "chai": "^4.4.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "ethers": "^6.11.1",
    "hardhat": "^2.20.1",
    "hardhat-gas-reporter": "^2.1.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "mocha": "^10.3.0",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.5.4",
    "solhint-plugin-prettier": "^0.1.0",
    "solidity-coverage": "^0.8.12",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  },
  "lint-staged": {
    "*.sol": ["solhint --fix", "prettier --write"],
    "*.ts": ["eslint --fix", "prettier --write"],
    "*.{json,yml,yaml,md}": ["prettier --write"]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
